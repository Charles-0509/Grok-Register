# Grok-Register config.env.example
# 本文件在每次 `grok start` / `grok config` 时会同步到 ~/.grok/config.env.example
# 正式配置请编辑: ~/.grok/config.env  （或运行: grok config）
#
# --- 不再写入 config.env 的运行参数（请用 CLI / 交互）---
#   注册数量:   grok start            → 提示输入
#               grok start -t 10
#   并发线程:   grok start            → 提示输入 1-8
#               grok start --thread 3
#   组合:       grok start -t 20 --thread 4
#
# --- 邮箱 ---
EMAIL_MODE=tempmail
# EMAIL_MODE=testmail
# TESTMAIL_API_KEY=
# TESTMAIL_NAMESPACE=
# TESTMAIL_DOMAIN=inbox.testmail.app
# EMAIL_MODE=custom
# EMAIL_DOMAIN=example.com
# EMAIL_API=http://127.0.0.1:8080

# --- 清障 (WARP + Privoxy + FlareSolverr) ---
CLEARANCE_ENABLED=1
REGISTER_PROXY=http://127.0.0.1:40080
FLARESOLVERR_URL=http://127.0.0.1:8191
CLEARANCE_PROXY=http://privoxy:8118
CLEARANCE_URLS=https://accounts.x.ai,https://x.ai,https://status.x.ai,https://console.x.ai,https://auth.x.ai

# --- Turnstile ---
# 提供方: browser（默认，常驻 CloakBrowser 池）| lite（外接 farm）| chromedp
TURNSTILE_PROVIDER=browser
# TURNSTILE_PROVIDER=lite
# LITE_SOLVER_URL=http://127.0.0.1:5072
# CHROME_PATH=

# --- 协议 / 临时邮箱限速 ---
PROTOCOL_HTTP=1
HTTP_POOL_SIZE=8
TEMPMAIL_LOL_RETRIES=30
TEMPMAIL_LOL_MIN_INTERVAL_MS=1500

# --- 进程代理（邮箱 HTTP 等；一般与 REGISTER_PROXY 一致）---
HTTPS_PROXY=http://127.0.0.1:40080
HTTP_PROXY=http://127.0.0.1:40080
NO_PROXY=127.0.0.1,localhost

# --- 探活 ---
PROBE_ENABLED=1
# PHYSICAL_CAP=0   # 高级：浏览器物理并发上限，0=跟 --thread

# --- CPA Management 上传 ---
# 宿主机 grok 必须用 127.0.0.1，不要写 docker 服务名 cli-proxy-api
# 路径需含 /v0/management
CPA_UPLOAD_ENABLED=0
CPA_MANAGEMENT_BASE=http://127.0.0.1:8317/v0/management
CPA_MANAGEMENT_KEY=
CPA_UPLOAD_TIMEOUT_SEC=30
CPA_UPLOAD_RETRIES=2
CPA_UPLOAD_NAME_TEMPLATE={email}.json
CPA_UPLOAD_VERIFY=1
CPA_UPLOAD_MODE=multipart
